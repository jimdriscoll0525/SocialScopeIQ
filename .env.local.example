# Copy this file to .env.local and fill in real values.
# Get these from your Supabase project dashboard: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Service role key — SECRET. Used by server scripts and cron jobs to write to the DB.
# Never commit this. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Anthropic API key for the response drafter. Get from console.anthropic.com
ANTHROPIC_API_KEY=YOUR-ANTHROPIC-KEY

# Optional: shared secret that the Vercel cron uses when calling /api/scout.
# Make this any long random string. Set the same value in Vercel cron headers.
CRON_SECRET=PICK-ANY-LONG-RANDOM-STRING

# Reddit OAuth (app-only / client_credentials). Required for the Reddit scout —
# Reddit blocks the old unauthenticated .json endpoint from Vercel's IPs.
# Create a free "script" app at https://www.reddit.com/prefs/apps then set both
# here AND in Vercel project env (Production + Preview).
# If unset, the Reddit scout safely returns no leads (it never errors the run).
REDDIT_CLIENT_ID=YOUR-REDDIT-APP-CLIENT-ID
REDDIT_CLIENT_SECRET=YOUR-REDDIT-APP-CLIENT-SECRET

# Optional: Stack Exchange API key. The scout works without it (300
# requests/day shared per IP). A free key from
# https://stackapps.com/apps/oauth/register raises the quota to 10,000/day
# and avoids shared-datacenter-IP throttling on Vercel. Leave unset to skip.
STACKEXCHANGE_API_KEY=
